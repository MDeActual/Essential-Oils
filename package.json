{
  "name": "essential-oils",
  "version": "1.0.0",
  "description": "Phyto.ai Architecture Package (v11 CANONICAL) Includes environment variable spec and example configuration files.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/__tests__/**"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MDeActual/Essential-Oils.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/MDeActual/Essential-Oils/issues"
  },
  "homepage": "https://github.com/MDeActual/Essential-Oils#readme",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.4.1",
    "jest": "^30.3.0",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "express": "^5.2.1"
  }
}
